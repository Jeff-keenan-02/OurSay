config:
  theme: neo-dark
  layout: elk
  look: neo
---
classDiagram
    class User {
        +int id
        +string username
        +string password_hash
        +string identity_token  (nullable)
        +timestamp created_at
        +login()
        +signup()
        +verifyIdentity()
    }
    class Poll {
        +int id
        +string title
        +string description
        +int created_by
        +timestamp created_at
        +createPoll()
        +getPolls()
    }

    class PollVote {
        +int id
        +int poll_id
        +int user_id  (nullable)
        +string choice
        +boolean is_verified
        +timestamp created_at
        +submitVote()
    }

    User --> Poll : "creates"
    User --> PollVote : "casts"
    Poll --> PollVote : "1..* votes"
    class Discussion {
        +int id
        +string title
        +string body
        +int user_id
        +timestamp created_at
        +createDiscussion()
    }

    class Comment {
        +int id
        +int discussion_id
        +int user_id
        +string text
        +timestamp created_at
        +addComment()
    }

    class DiscussionVote {
        +int id
        +int discussion_id
        +int user_id
        +int value (+1/-1)
        +timestamp created_at
        +castVote()
    }

    User --> Discussion : "starts"
    User --> Comment : "writes"
    User --> DiscussionVote : "votes on"
    Discussion --> Comment : "has many"
    Discussion --> DiscussionVote : "has many"
    class VerificationService {
        +uploadPassportImage()
        +parsePassport()  // PixLab or ML Kit
        +generateIdentityToken()
    }

    User --> VerificationService : "requests verification"



