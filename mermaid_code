%% Use Case Diagram for OurSay Mobile System
%% Requires Mermaid 10+ (supports use case diagrams)

usecaseDiagram

actor User
actor Admin

rectangle "OurSay Mobile System" {

    User --> (View Polls)
    User --> (Vote on Polls)
    User --> (View Discussions)
    User --> (Create Discussion)
    User --> (Comment on Discussion)
    User --> (Verify Identity)

    (Verify Identity) ..> (Verified vote on polls) : <<extend>>
    (Verify Identity) ..> (Verified Create Discussion) : <<extend>>
    (Verify Identity) ..> (Verified Comment on discussion) : <<extend>>

    Admin --> (Create Poll)
    Admin --> (Moderate Discussions)
}


---
config:
  theme: neo-dark
---
sequenceDiagram
    actor User
    participant RN as React Native App
    participant API as Backend
    participant DB as PostgreSQL

    User ->> RN: Enter username & password
    RN ->> API: POST /login
    API ->> DB: SELECT user WHERE username
    DB -->> API: User record + password hash
    API ->> API: Verify password (bcrypt compare)
    API -->> RN: Login success + user object
    RN -->> User: Redirect to Home



