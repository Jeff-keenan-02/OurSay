classDiagram
    class users {
        +int id
        +string username
        +string password_hash
        +smallint verification_tier
        +timestamp created_at
    }
    class topics {
        +int id
        +string title
        +string description
        +boolean is_weekly
        +timestamp created_at
    }
    class poll_groups {
        +int id
        +int topic_id
        +string title
        +smallint required_verification_tier
        +timestamp created_at
    }
    class polls {
        +int id
        +int poll_group_id
        +string question
        +string description
        +timestamp created_at
    }
    class petitions {
        +int id
        +int topic_id
        +string title
        +string description
        +smallint required_verification_tier
        +int signature_goal
        +timestamp created_at
    }
    class discussions {
        +int id
        +int topic_id
        +string title
        +string body
        +int created_by
        +timestamp created_at
    }
    class verifications {
        +int id
        +int user_id
        +enum type
        +smallint level
        +string passport_hash
        +timestamp issued_at
        +timestamp expires_at
        +boolean revoked
    }
    class action_tokens {
        +string token_hash
        +string action_type
        +int poll_id
        +int petition_id
        +timestamp expires_at
        +boolean used
    }
    class poll_votes {
        +int id
        +int poll_id
        +string token_hash
        +string choice
        +date created_at
    }
    class petition_signatures {
        +int id
        +int petition_id
        +string token_hash
        +date created_at
    }
    class poll_identity_usage {
        +int poll_id
        +string passport_hash
    }
    class petition_identity_usage {
        +int petition_id
        +string passport_hash
    }
    class poll_participation {
        +int user_id
        +int poll_id
        +date participated_at
    }
    class petition_participation {
        +int user_id
        +int petition_id
        +date participated_at
    }

    users "1" --> "0..*" verifications : has
    users "1" --> "0..*" discussions : creates
    users "1" --> "0..*" poll_participation : tracked by
    users "1" --> "0..*" petition_participation : tracked by
    topics "1" --> "0..*" poll_groups : contains
    topics "1" --> "0..*" petitions : contains
    topics "1" --> "0..*" discussions : contains
    poll_groups "1" --> "0..*" polls : contains
    polls "1" --> "0..*" poll_votes : receives
    polls "1" --> "0..*" poll_identity_usage : tracks
    polls "1" --> "0..*" action_tokens : referenced by
    petitions "1" --> "0..*" petition_signatures : receives
    petitions "1" --> "0..*" petition_identity_usage : tracks
    petitions "1" --> "0..*" action_tokens : referenced by
    action_tokens "1" --> "0..1" poll_votes : produces
    action_tokens "1" --> "0..1" petition_signatures : produces
